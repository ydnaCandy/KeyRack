{
  "name": "KeyRack (Electron + Node 20)",
  "build": {
    "dockerfile": "Dockerfile"
  },

  // better-sqlite3 のネイティブモジュール再ビルドのため
  // npm install 後に electron-builder install-app-deps を実行
  "postCreateCommand": "npm install && npx electron-builder install-app-deps",

  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "ms-vscode.vscode-typescript-next",
        "lokalise.i18n-ally"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "typescript.tsdk": "node_modules/typescript/lib"
      }
    }
  },

  // Electron の GUI 起動時は仮想ディスプレイが必要
  // 起動手順: start-xvfb && npm run dev:container
  // (コンテナ環境では --no-sandbox --disable-gpu が必要なため dev:container を使用)
  "remoteEnv": {
    "DISPLAY": ":99"
  },

  "remoteUser": "node"
}
